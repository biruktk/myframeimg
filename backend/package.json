{
  "name": "myframe-server",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "cast-frame": "node scripts/cast-to-frame.cjs",
    "dump-public-site-fallback": "ts-node --transpile-only scripts/dump-public-site-fallback.ts",
    "sync-official-pages": "node scripts/sync-official-pages.cjs",
    "postbuild": "node scripts/copy-official-pages-snapshot.cjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "firebase-admin": "^14.2.0",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.10.4",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^9.0.3",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.15.29",
    "@types/nodemailer": "^8.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
