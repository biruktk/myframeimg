# Same layout as VPS `backend/.env`. MQTT: use 127.0.0.1 when Node and Mosquitto run on the same host.

PORT=3001
UPLOAD_DIR=./uploads
CORS_ORIGINS=

FRAME_PAIRING_TOKEN=framepass2026
# WeChat Mini Program server → API (report sales, read summary). Bearer or x-wechat-mini-secret.
#WECHAT_MINI_API_SECRET=
ADMIN_TOKEN=framepass2026
# Optional: signing key for app JWTs from /api/auth/* (falls back to ADMIN_TOKEN if long enough).
#APP_JWT_SECRET=

# Google Sign-In (Flutter app + web portal). Comma-separated OAuth 2.0 client IDs:
# Web application + Android + iOS from https://console.cloud.google.com/apis/credentials
# Example: GOOGLE_OAUTH_CLIENT_IDS=123-web.apps.googleusercontent.com,123-android.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_IDS=824694546060-9rlpc8r18kv38t0lvdkktbeai8nn7s58.apps.googleusercontent.com
# Mobile app browser sign-in (/mobile/google-signin): add API origins to the Web client, e.g.
# http://128.241.231.234:3001 and http://myframe.ink:3001 under Authorized JavaScript origins.
UPLOADS_PER_MINUTE=30

MQTT_URL=mqtt://device:framepass2026@127.0.0.1:1883
MQTT_USER=
MQTT_PASSWORD=
# Set to 1 to log MQTT payloads rx/tx in API stdout (heavy; troubleshooting only).
FRAME_MQTT_DEBUG=
# Set to 1 to send absolute `imgurl` in MQTT `play` (default: path-only + host/port; see API doc).
MQTT_PLAY_FULL_IMGURL=

# XT ePaper / ESP32: JPEG/PNG uploads → `.bin` (960004 B, 13.3E6); JPEG kept beside `.bin`; MQTT NEVER uses JPEG.
FRAME_MYFM_ENCODE=1

# XT / ESP32 downloader is usually HTTP-only. Omit or set http://YOUR_VPS_IP:3001 (not https / :443 unless firmware supports TLS).
PUBLIC_BASE_URL=http://127.0.0.1:3001
#PUBLIC_MEDIA_BASE_URL=http://128.241.231.234:3001

# Only if MQTT play URLs must use https:// explicitly (non-standard on stock XT firmware).
# FRAME_PLAY_ALLOW_HTTPS=1

FRAME_API_SECRET=framepass2026
FRAME_JWT_SECRET=framepass2026
