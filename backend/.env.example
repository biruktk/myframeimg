# Same layout as VPS `backend/.env`. MQTT: use 127.0.0.1 when Node and Mosquitto run on the same host.

PORT=3001
UPLOAD_DIR=./uploads
CORS_ORIGINS=

FRAME_PAIRING_TOKEN=framepass2026
ADMIN_TOKEN=framepass2026
UPLOADS_PER_MINUTE=30

MQTT_URL=mqtt://device:framepass2026@127.0.0.1:1883
MQTT_USER=
MQTT_PASSWORD=
PUBLIC_BASE_URL=https://myframe.ink

FRAME_API_SECRET=framepass2026
FRAME_JWT_SECRET=framepass2026
FRAME_PLAY_ALLOW_HTTPS=1
PUBLIC_MEDIA_BASE_URL=http://47.76.164.162

# WeChat Mini Program credentials
WECHAT_MINI_APPID=wx3852473748106054
WECHAT_MINI_APPSECRET=02efdbbbd0fecb4087eca180fb604e2f

# Google OAuth — comma-separated client IDs + secret
#GOOGLE_OAUTH_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-ios-client-id.apps.googleusercontent.com
#GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# WeChat Open Platform (mobile app)
#WECHAT_APPID=wx452059b9ecaf1fc0
#WECHAT_APPSECRET=424c9f0012ef7eabc4de77346dc81b6d

# WeChat Mini Program API secret (server-to-server)
#WECHAT_MINI_API_SECRET=a7790f7ce9e61c85f2903a3e35782d9501e60558c54ec69c

# Firebase Admin SDK – service account JSON
# Either set FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/myframe-firebase.json
# or place a firebase-*.json file in backend/secrets/ (auto-detected).
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/myframe-b9ba9-firebase-adminsdk-fbsvc-4ffa7f2aa6.json

# SMTP for password-reset emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@myframe.ink
SMTP_PASS=your-smtp-password
SMTP_FROM="MyFrame <noreply@myframe.ink>"
