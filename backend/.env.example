# Same layout as VPS `backend/.env`. MQTT: use 127.0.0.1 when Node and Mosquitto run on the same host.

PORT=3001
UPLOAD_DIR=./uploads
CORS_ORIGINS=

FRAME_PAIRING_TOKEN=framepass2026
ADMIN_TOKEN=framepass2026
UPLOADS_PER_MINUTE=30

MQTT_URL=mqtt://device:framepass2026@127.0.0.1:1883
MQTT_USER=
MQTT_PASSWORD=
# Set to 1 to log MQTT payloads rx/tx in API stdout (heavy; troubleshooting only).
FRAME_MQTT_DEBUG=
# Set to 1 to send absolute `imgurl` in MQTT `play` (default: path-only + host/port; see API doc).
MQTT_PLAY_FULL_IMGURL=

# VPS: after JPEG/PNG upload, build MYFM .bin sibling (Flutter-compatible) for MQTT play. Set 0 to skip.
FRAME_MYFM_ENCODE=1

# Allow MQTT to push JPEG when MYFM encode fails (frame usually will not render). Omit for strict .bin-only.
# FRAME_ALLOW_JPEG_MQTT=1

# Host:port where the FRAME does HTTP GET for play imgurl (Express serves /frame-media on PORT).
# Do NOT point this at myframe.ink:443 unless reverse-proxy forwards /frame-media to this API —
# Next/marketing sites return HTML/404 there and uploads will never display.
PUBLIC_BASE_URL=http://127.0.0.1:3001
# If the site domain differs from API, set media origin explicitly:
#PUBLIC_MEDIA_BASE_URL=http://YOUR_VPS_IP:3001

FRAME_API_SECRET=framepass2026
FRAME_JWT_SECRET=framepass2026
