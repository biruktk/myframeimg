# Template only for local/private setup.
# On the VPS, do NOT copy this over backend/.env. The existing backend/.env is the source of truth.

PORT=3001
UPLOAD_DIR=./uploads
CORS_ORIGINS=

FRAME_PAIRING_TOKEN=change-me
ADMIN_TOKEN=framepass2026
UPLOADS_PER_MINUTE=30

MQTT_URL=mqtt://device:password@127.0.0.1:1883
MQTT_USER=
MQTT_PASSWORD=
PUBLIC_BASE_URL=http://YOUR_VPS_IP

FRAME_API_SECRET=change-me
FRAME_JWT_SECRET=change-me
FRAME_PLAY_ALLOW_HTTPS=1
PUBLIC_MEDIA_BASE_URL=http://YOUR_VPS_IP
FRAME_MQTT_PORT=80
FRAME_MEDIA_PORT=80

WECHAT_MINI_APPID=
WECHAT_MINI_APPSECRET=

GOOGLE_OAUTH_CLIENT_IDS=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com,YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=
