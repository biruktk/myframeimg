# Same as committed `backend/.env`. MQTT: use 127.0.0.1 when API and Mosquitto run on host; use
# host.docker.internal in .env when API runs in Docker (see deploy/vps/docker-compose).

PORT=3001
UPLOAD_DIR=./uploads
CORS_ORIGINS=

FRAME_PAIRING_TOKEN=framepass2026
ADMIN_TOKEN=framepass2026
UPLOADS_PER_MINUTE=30

MQTT_URL=mqtt://device:framepass2026@127.0.0.1:1883
MQTT_USER=
MQTT_PASSWORD=
# Set to 1 to log MQTT payloads rx/tx in API stdout (heavy; troubleshooting only).
FRAME_MQTT_DEBUG=
# Set to 1 to send absolute `imgurl` in MQTT `play` (default: path-only + host/port; see API doc).
MQTT_PLAY_FULL_IMGURL=
# Often the marketing Next site; frame images are NOT served from here unless you proxy /frame-media → API.
PUBLIC_BASE_URL=https://myframe.ink
# Base URL where Express actually serves `/api` + `/frame-media` (MQTT `play`, eink download). Overrides image URLs only.
# Example nginx: APP_DOMAIN=myframe.ink → use API_DOMAIN here: https://api.myframe.ink
PUBLIC_MEDIA_BASE_URL=https://api.myframe.ink

FRAME_API_SECRET=framepass2026
FRAME_JWT_SECRET=framepass2026
