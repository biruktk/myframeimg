APP_DOMAIN=myframe.ink
# API subdomain (Nginx → Express :3001). Browser /api/* on myframe.ink is proxied by Next.js.
API_DOMAIN=api.myframe.ink
NEXT_PUBLIC_SITE_URL=https://myframe.ink
NEXT_PUBLIC_DEVICE_ID=YX-133P-001

CORS_ORIGINS=https://myframe.ink,https://www.myframe.ink

FRAME_PAIRING_TOKEN=framepass2026
ADMIN_TOKEN=framepass2026
UPLOADS_PER_MINUTE=30

# API on host: broker on same machine
MQTT_URL=mqtt://device:framepass2026@127.0.0.1:1883
PUBLIC_BASE_URL=https://myframe.ink
PUBLIC_MEDIA_BASE_URL=https://myframe.ink
MYFRAME_API_URL=http://127.0.0.1:3001
FRAME_API_SECRET=framepass2026
FRAME_JWT_SECRET=framepass2026
