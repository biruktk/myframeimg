# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Prefer not committing live `.env` elsewhere; these are explicitly tracked for VPS workflow.
.env*
!**/.env.example
!**/.env*.example
!backend/.env
!deploy/vps/.env.prod

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
