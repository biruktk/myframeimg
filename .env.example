# Express API (`server/`) — used by Next.js API routes (server-side only).
# Copy this file to `web/.env` for local dev: cp .env.example .env
MYFRAME_API_URL=http://127.0.0.1:3001

# Must match `web/backend/.env` → ADMIN_TOKEN (session cookie + x-admin-token proxy).
ADMIN_TOKEN=framepass2026
# CMS login at http://localhost:3000/admin
ADMIN_USER=admin
ADMIN_PASS=admin

# Optional: multipart `device_id` field when uploading from the web Send page.
NEXT_PUBLIC_DEVICE_ID=YX-133P-001

# Google Sign-In on https://myframe.ink/en/auth — Web application client ID from Google Cloud Console.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=824694546060-9rlpc8r18kv38t0lvdkktbeai8nn7s58.apps.googleusercontent.com
